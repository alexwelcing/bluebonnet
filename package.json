{
  "name": "bluebonnet",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "An analog-horror puzzle mystery played through a recovered Texas DPS dashcam tape.",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "npm run lint:shotlist && tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint:shotlist": "node tools/shotlistLint.mjs"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
