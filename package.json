{
  "name": "bluebonnet",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "An analog-horror puzzle mystery played through a vanished journalist's recovered Hi8 tape with nine missing minutes.",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "npm run lint:shotlist && tsc --noEmit && vite build",
    "preview": "vite preview",
    "bridge:serve": "python3 -m http.server 8123 --directory .bridge",
    "doctor": "node tools/bluebonnetDoctor.mjs",
    "gate": "node tools/bluebonnetGate.mjs",
    "playtest:smoke": "node tools/playtestSmoke.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint:shotlist": "node tools/shotlistLint.mjs"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "pngjs": "^7.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
